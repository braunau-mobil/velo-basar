@page
@model Pages.Generic.ListPageModel<Country>
@{
    ViewData["Title"] = Localizer["Länder"];
}

    <dynamic-table page-model="@Model" title-text="@Localizer["Länder"]" new-item-text="@Localizer["Neues Land"]">
        <dynamic-column property-name="Id" width="auto"></dynamic-column>
        <dynamic-column property-name="Name" width="50%"></dynamic-column>
        <dynamic-column property-name="Iso3166Alpha3Code" width="50%"></dynamic-column>
    </dynamic-table>
