@model Pages.Generic.IEditPageModel

<form method="post">
    <div class="card my-3">
        <div class="card-header d-flex justify-content-between align-items-md-center">
            <div class="mr-auto"><h5>@ViewData["Title"]</h5></div>
            <div class="d-flex justify-content-end">
                <input type="submit" value="@Localizer["Speichern"]" class="btn btn-primary mx-1" velo-page="@Model.ListPageOrigin()" />
                <a velo-page="@Model.ListPageOrigin()" class="btn btn-secondary mx-1">@Localizer["Abbrechen"]</a>
            </div>
        </div>

        <div class="card-body">
            <dynamic-form velo-model="@Model.Item"></dynamic-form>
        </div>
    </div>
</form>

