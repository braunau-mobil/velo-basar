@page
@model Pages.Generic.ListPageModel<ProductType>
@{
    ViewData["Title"] = Localizer["Artikel Typen"];
}

<dynamic-table page-model="@Model" title-text="@Localizer["Artikel Typen"]" new-item-text="@Localizer["Neuer Produkt Typ"]">
    <dynamic-column property-name="Id" width="auto"></dynamic-column>
    <dynamic-column property-name="Name" width="20%"></dynamic-column>
    <dynamic-column property-name="Description" width="80%"></dynamic-column>
</dynamic-table>
