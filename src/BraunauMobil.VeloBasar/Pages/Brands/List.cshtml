@page
@model Pages.Generic.ListPageModel<Brand>

@{
    ViewData["Title"] = Localizer["Marken"];
}

<dynamic-table page-model="@Model" title-text="@Localizer["Marken"]" new-item-text="@Localizer["Neue Marke"]">
    <dynamic-column property-name="Id" width="auto"></dynamic-column>
    <dynamic-column property-name="Name" width="100%"></dynamic-column>
</dynamic-table>

