@page
@model Pages.Generic.ListPageModel<Basar>

@{
    ViewData["Title"] = Localizer["Basare"];
}

<dynamic-table page-model="@Model" title-text="@Localizer["Basare"]" new-item-text="@Localizer["Neuer Basar"]">
    <dynamic-column property-name="Id" width="auto"></dynamic-column>
    <dynamic-column property-name="Date" width="20%"></dynamic-column>
    <dynamic-column property-name="Name" width="40%"></dynamic-column>
    <dynamic-column property-name="Location" width="40%"></dynamic-column>
    
    <dynamic-column get-page="@item => this.GetPage<DetailsModel>(new DetailsParameter { BasarId = ((Basar)item).Id })" page-text="Details" width="auto"></dynamic-column>
</dynamic-table>

